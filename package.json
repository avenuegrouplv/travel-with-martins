{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:cms": "tinacms dev -c \"vite --port=3000 --host=0.0.0.0\"",
    "build": "vite build",
    "build:cms": "node -e \"const { execSync } = require('child_process'); const cid = process.env.TINA_CLIENT_ID; if (!cid || cid === 'null' || cid === 'undefined') { console.log('Building CMS locally...'); execSync('tinacms build --local', { stdio: 'inherit' }); } else { console.log('Building CMS for TinaCloud...'); execSync('tinacms build --skip-cloud-checks', { stdio: 'inherit' }); }\" && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "tinacms": "^3.10.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.5.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jimp": "^1.6.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
